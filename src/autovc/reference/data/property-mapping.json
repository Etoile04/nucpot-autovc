{
  "version": "1.0.0",
  "description": "Property name mapping across L1 (reference_values), L2 (NFMD), L3 (llm-wiki/ontofuel) with validation ranges.",
  "mappings": [
    {
      "ref_property": "lattice_constant",
      "ref_unit": "Å",
